# Database
DATABASE_URL=postgresql://sale_user:changeme@localhost:5432/sale_db

# JWT
JWT_SECRET=change-this-to-a-very-long-random-string-at-least-32-chars

# API
API_PORT=4000
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000

# Web — kosongkan agar pakai relative URL (lewat NGINX), atau isi domain lengkap
NEXT_PUBLIC_API_URL=

# Redis (optional, untuk pub/sub multi-instance)
# REDIS_URL=redis://localhost:6379

# Environment
NODE_ENV=development
